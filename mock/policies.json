    "mockOnly": true,
    "rules": [
      {
        "type": "transaction_amount",
        "asset": "USDC",
        "threshold": "10000.00",
        "action": "require_approval"
      }
    ]
  },
  {
    "id": "policy_002",
    "organizationId": "org_sandbank_001",
    "name": "Frozen wallet transfer block",
    "description": "Show how a frozen wallet state would appear in a reference control workflow.",
    "status": "active",
    "scope": "wallet status",
    "mockOnly": true,
    "rules": [
      {
        "type": "source_wallet_status",
        "status": "frozen",
        "action": "block_in_reference"
      }
    ]
  },
  {
    "id": "policy_003",
    "organizationId": "org_sandbank_002",
